# ─────────────────────────────────────────────────────────────────────────────
#  Revenue AI — Environment Variables Template
#  Copy this file to .env and fill in your values:
#    cp .env.example .env
#  Never commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Django core ───────────────────────────────────────────────────────────────
# Generate a strong key: python -c "from django.core.management.utils import get_random_secret_key; print(get_random_secret_key())"
SECRET_KEY=change-me-to-a-long-random-50-char-string
DEBUG=False
ALLOWED_HOSTS=yourdomain.com,www.yourdomain.com

# ── Google Gemini API ─────────────────────────────────────────────────────────
GEMINI_API_KEY=your-gemini-api-key-here

# ── Database ──────────────────────────────────────────────────────────────────
POSTGRES_DB=revenueai
POSTGRES_USER=revenueai
POSTGRES_PASSWORD=change-me-use-a-strong-password
POSTGRES_HOST=db
POSTGRES_PORT=5432
# sslmode: disable | allow | prefer | require | verify-ca | verify-full
POSTGRES_SSLMODE=prefer

# ── Cache / Sessions (Redis) ──────────────────────────────────────────────────
# Leave empty to use in-memory cache (LocMemCache)
REDIS_URL=redis://redis:6379/0

# ── Security ──────────────────────────────────────────────────────────────────
# Set to False only if terminating TLS outside the container (e.g. load balancer)
SECURE_SSL_REDIRECT=True

# ── CORS ──────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins (no trailing slash)
CORS_ALLOWED_ORIGINS=https://yourdomain.com,https://www.yourdomain.com

# ── Email (SMTP) ──────────────────────────────────────────────────────────────
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USE_TLS=True
EMAIL_HOST_USER=your-email@gmail.com
EMAIL_HOST_PASSWORD=your-app-password-here

